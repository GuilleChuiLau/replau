POSTGREST_BASE_URL=http://127.0.0.1:3000

SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false

SMTP_USERNAME=your_email@replau.com
SMTP_PASSWORD=your_password_or_app_password
SMTP_FROM=your_email@replau.com

POLL_SECONDS=20
BATCH_LIMIT=10
REQUEST_TIMEOUT=30

EMAIL_DRY_RUN=true

LOG_LEVEL=INFO
