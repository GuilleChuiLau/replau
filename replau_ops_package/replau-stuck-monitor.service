[Unit]
Description=Replau stuck WhatsApp/email monitor

[Service]
Type=oneshot
User=guill
Group=guill
WorkingDirectory=/opt/replau_ops
EnvironmentFile=/etc/replau-ops.env
ExecStart=/opt/replau_ops/.venv/bin/python /opt/replau_ops/replau_stuck_monitor.py
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
