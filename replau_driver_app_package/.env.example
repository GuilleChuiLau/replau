POSTGREST_BASE_URL=http://127.0.0.1:3000
APP_HOST=127.0.0.1
APP_PORT=8797
REQUEST_TIMEOUT=10

# Set true before exposing admin review routes beyond local-only use.
REQUIRE_ADMIN_TOKEN=true
ADMIN_TOKEN=change-me

# Required for every browser/API driver route. Keep the app on loopback unless
# TLS is provided by a trusted reverse proxy.
REQUIRE_DRIVER_AUTH=true
DRIVER_AUTH_USERNAME=driver
DRIVER_AUTH_PASSWORD=change-me

REPLAU_DRIVER_DOCUMENT_DIR=/home/guill/.openclaw/workspace/replau_driver_documents
REPLAU_DRIVER_MAX_UPLOAD_BYTES=8388608
