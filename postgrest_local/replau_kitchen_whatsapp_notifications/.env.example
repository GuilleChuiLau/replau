POSTGREST_BASE_URL=http://127.0.0.1:3000

# Keep true until OpenClaw outbound sending is configured.
WHATSAPP_DRY_RUN=true

# Configure this when OpenClaw exposes a send-message route.
# Example placeholder:
# OPENCLAW_SEND_URL=http://127.0.0.1:18789/hooks/whatsapp-send
OPENCLAW_SEND_URL=

OPENCLAW_HOOK_TOKEN=RESTRICTED

POLL_SECONDS=5
BATCH_LIMIT=10
MAX_ATTEMPTS=5
REQUEST_TIMEOUT=30
LOG_LEVEL=INFO
